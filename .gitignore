# Virtual environment
.venv/

# Dataset symlinks — data lives outside the repo
data/

# External dataset (too large for git)
external/kaggle_irt_pv/

# Trained model weights (large binaries — exclude specific extensions, not the folder)
results/logs/*.keras
results/logs/*.h5
results/logs/*.weights.h5
!results/logs/.gitkeep

# Python artefacts
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/

# macOS
.DS_Store

# Jupyter
.ipynb_checkpoints/
*.ipynb

# TensorBoard logs
logs/

# Manuscript — kept local, not published to the code repo
manuscript/

# Large numpy prediction arrays — not needed for reproducibility
results/tables/preds_*.npy

# Scratch / one-off scripts and submission admin (not part of reproducibility)
continue_ablation.py
run_ablation_cv.py
finish_resolution_diagnosis.py
make_combined_ablation_charts.py
make_cover_letter.py
requirements_backup.txt
results/ablation_cv_run.log

# Manuscript-generation tooling and figures (kept local, not in the code repo)
generate_figures.py
fill_results.py
verify_refs.py
diagrams/
results/figures/
