          vertex="1" parent="1">
          <mxGeometry x="280" y="685" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="output_cm" value="cross_domain_cm.png&lt;br/&gt;(best model CM)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="460" y="685" width="150" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="a8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="metrics" target="output_csv" parent="1">
