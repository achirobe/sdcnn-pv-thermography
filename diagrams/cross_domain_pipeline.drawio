        </mxCell>
        <mxCell id="a9" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="metrics" target="output_cm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ── ANNOTATION NOTE ── -->
        <mxCell id="note_domain" value="Domain differences:&lt;br/&gt;• Camera spec / calibration&lt;br/&gt;• Flight altitude + angle&lt;br/&gt;• Climate (tropical vs. temperate)&lt;br/&gt;• Panel type + age&lt;br/&gt;• Irradiance conditions"
          style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontColor=#333333;fontSize=9;"
          vertex="1" parent="1">
          <mxGeometry x="700" y="200" width="220" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="note_gap" value="Domain Gap interpretation:&lt;br/&gt;Δ &lt; 0.05 → Excellent generalisation&lt;br/&gt;Δ 0.05–0.15 → Moderate — acceptable&lt;br/&gt;Δ &gt; 0.15 → Large — domain shift noted&lt;br/&gt;(motivates domain adaptation future work)"
          style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontColor=#333333;fontSize=9;"
