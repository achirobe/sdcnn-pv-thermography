<mxfile host="app.diagrams.net" modified="2026-06-01" version="21.0.0">
  <diagram name="Cross-Domain Evaluation Pipeline" id="cross_domain">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Zero-Shot Cross-Domain Evaluation Pipeline"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1"
          vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="960" height="40" as="geometry"/>
        </mxCell>

        <!-- ── TRAINING DOMAIN (Ghana) ── -->
        <mxCell id="gh_label" value="TRAINING DOMAIN (Ghana)"
          style="text;html=1;strokeColor=none;fillColor=#dae8fc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=12;fontStyle=1;fillColor=#1e88e5;fontColor=white;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="90" width="240" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="gh_data" value="Ghana IRT-PV Dataset&lt;br/&gt;230 images (detection)&lt;br/&gt;Balanced: 50/50 faulty/clean&lt;br/&gt;UAV acquisition, tropical climate"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="200" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="cv_train" value="5-Fold Stratified CV Training&lt;br/&gt;SDCNN | VGG-16 | MobileNetV2&lt;br/&gt;EfficientNet-B0&lt;br/&gt;SEED=42, EPOCHS≤50"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="260" width="200" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="best_weights" value="Best-Fold Weights&lt;br/&gt;best_detection_{arch}.keras&lt;br/&gt;(highest F1 across folds)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="370" width="200" height="70" as="geometry"/>
        </mxCell>

        <!-- arrows in training column -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="gh_data" target="cv_train" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="cv_train" target="best_weights" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ── SEPARATOR: NO RETRAINING ── -->
        <mxCell id="sep_line" value=""
          style="endArrow=none;startArrow=none;html=1;dashed=1;strokeColor=#FF0000;strokeWidth=3;"
          edge="1" parent="1">
          <mxGeometry x="340" y="80" width="10" height="10" as="geometry">
            <Array as="points">
              <mxPoint x="340" y="80"/>
              <mxPoint x="340" y="700"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="sep_label" value="NO FINE-TUNING"
          style="text;html=1;strokeColor=#FF0000;fillColor=#FFE6E6;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#CC0000;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="297" y="380" width="90" height="40" as="geometry"/>
        </mxCell>

        <!-- ── TEST DOMAIN (Italy/Pierdicca) ── -->
        <mxCell id="it_label" value="TEST DOMAIN (Italy — Pierdicca 2020)"
          style="text;html=1;strokeColor=none;fillColor=#FF5722;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=12;fontStyle=1;fontColor=white;"
          vertex="1" parent="1">
          <mxGeometry x="430" y="90" width="290" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="it_data" value="Pierdicca IRT-PV Dataset&lt;br/&gt;137 images total&lt;br/&gt;40 fault / 97 no-fault&lt;br/&gt;Imbalanced: 29%/71%&lt;br/&gt;Italian PV, temperate climate"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="430" y="150" width="200" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="it_label2" value="Label Derivation:&lt;br/&gt;JSON annotation per module&lt;br/&gt;ANY defected_module=True → fault(1)&lt;br/&gt;ALL defected_module=False → no-fault(0)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="430" y="260" width="200" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="it_ds" value="tf.data pipeline&lt;br/&gt;Resize 224×224 | Normalize [0,1]&lt;br/&gt;No augmentation&lt;br/&gt;Batch=32"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="430" y="360" width="200" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="it_data" target="it_label2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="it_label2" target="it_ds" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ── INFERENCE ── -->
        <mxCell id="infer" value="Zero-Shot Inference&lt;br/&gt;model.predict(ext_ds)&lt;br/&gt;threshold = 0.5"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="380" y="475" width="180" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="best_weights" target="infer" parent="1">
