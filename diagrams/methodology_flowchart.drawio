        <mxCell id="sdcnn" value="&lt;b&gt;SDCNN (proposed)&lt;/b&gt;&lt;br/&gt;3× Conv+MaxPool&lt;br/&gt;(32, 64, 128 filters)&lt;br/&gt;Dense(128) + Dropout(0.5)&lt;br/&gt;Sigmoid output"
